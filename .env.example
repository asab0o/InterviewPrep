# ============================================================
# 環境変数テンプレート（docs/requirements.md 12章 準拠）
# 実際の値を入れた .env は絶対にコミットしないこと（リポジトリの.gitignoreで除外必須）。
# Lightsail上では /opt/app/shared/.env に配置し、CIのデプロイでは上書きされない運用とする
# （docs/infra-setup.md 6章 / infra/scripts/deploy-backend.sh 参照）。
# ============================================================

# --- Anthropic API（UMPIRE解説生成・フレーズ翻訳サジェスト用） ---
# 発行元: https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Anthropic 使用モデルID（open-questions Q3で解決済み） ---
# モデルIDはコードに埋め込まず環境変数で外出しする。新モデルへの切り替えはこの値の変更のみで行う。
# 初期値は2026-07-04時点の最新安定版（UMPIRE=Sonnet系、翻訳=Haiku系。要件定義5.3/5.5章）
ANTHROPIC_MODEL_UMPIRE=claude-sonnet-5
ANTHROPIC_MODEL_TRANSLATE=claude-haiku-4-5-20251001

# --- GitHub OAuth App（ログイン認証・GitHub連携pushの両方に使用） ---
# 発行元: GitHub Settings > Developer settings > OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- 単一ユーザー制限（13章） ---
# このGitHubユーザー名と一致するアカウントのみログインを許可する。それ以外は拒否する。
GITHUB_ALLOWED_USERNAME=asab0o

# --- Express セッション用シークレット ---
# ランダムな長い文字列を生成して設定すること。生成例: openssl rand -base64 48
SESSION_SECRET=

# --- SQLiteファイルの保存先パス ---
# Lightsailインスタンス上の絶対パスを指定する（infra/scripts/bootstrap.shが作成する/opt/app/data配下を推奨）
DB_PATH=/opt/app/data/app.db

# --- GitHub連携push先リポジトリ（5.4節） ---
GITHUB_REPO_OWNER=asab0o
GITHUB_REPO_NAME=leetcode-interview-prep

# --- GitHub push用トークン（open-questions Q8で解決済み） ---
# ログイン用のGitHub OAuthとは別に、Fine-grained PATを発行して使う。
# 発行元: GitHub Settings > Developer settings > Personal access tokens > Fine-grained tokens
# 設定内容: Repository access を GITHUB_REPO_NAME のみに限定 / Permissions は Contents: Read and write のみ
# （ログイン用OAuthのスコープには repo を含めない。認証専用に保つ）
GITHUB_PUSH_TOKEN=

# --- Expressサーバーのポート・実行環境 ---
PORT=3000
NODE_ENV=production

# 注：FRONTEND_ORIGIN（CORS許可オリジン）は不要。Amplify Hostingのリライトで
# ブラウザからは常に同一オリジン扱いになるため、CORS設定自体を行わない方式に変更した
# （docs/infra-setup.md 0章・7.2章、docs/design/02-api-design.md 参照）。
