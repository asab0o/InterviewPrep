# ============================================================
# backend用 環境変数テンプレート（scaffold段階）
#
# 実際の値を入れた .env は絶対にコミットしないこと（ルートの.gitignoreで除外済み）。
# ローカル開発時はこのファイルを `backend/.env` としてコピーして使う。
# 本番（Lightsail）では /opt/app/shared/.env に配置され、dotenvが起動時のcwdから読み込む
# （docs/infra-setup.md 6章 / infra/scripts/deploy-backend.sh 参照。pm2のenv_fileオプションは使わない）。
#
# 完成版（全変数）はリポジトリルートの .env.example
# （docs/requirements.md 12章準拠のテンプレート）を参照。
# 現時点のscaffoldではPORT/NODE_ENVのみ実際に使用する。以下はPLAN.mdの実装順に沿って
# 有効化していく変数（今回のscaffoldでは未実装のためコメントアウトのまま）。
# ============================================================

# --- Expressサーバーのポート・実行環境（このscaffoldで使用） ---
PORT=3000
NODE_ENV=development

# --- Anthropic API（翻訳サジェスト = POST /api/translate、UMPIRE解説生成 =
#     POST /api/problems/:id/umpire, POST /api/umpire/preview で使用） ---
# 未設定でもサーバー自体は起動する（他のAPI・認証には影響しない）。
# 各エンドポイントを呼んだ時点でキー未設定なら503を返す。
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_TRANSLATE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_UMPIRE=claude-sonnet-5

# --- 以下は次ステップ以降で使用予定（今回のscaffoldでは未使用） ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_USERNAME=asab0o
SESSION_SECRET=replace-with-at-least-32-random-characters
DB_PATH=./data/app.db

# --- ブラウザから見たアプリの公開URL（GitHub OAuthのredirect_uri組み立てに使用） ---
# GitHub OAuth Appに登録したAuthorization callback URLのオリジンと完全一致させること。
# ローカル開発ではViteの開発サーバー（/auth をExpressへプロキシ）のURLを指定する。
# 本番はAmplifyのURL（https必須。例: https://main.xxxxx.amplifyapp.com）。
PUBLIC_APP_URL=http://localhost:5173

# --- GitHub連携push（POST /api/github/check, POST /api/github/push で使用） ---
# ログイン用のGitHub OAuthとは別に、対象リポジトリ1つ・Contents:Read and write権限のみに
# 絞ったFine-grained PATを発行して使う（docs/design/05-open-questions.md Q8参照）。
# 未設定でもサーバー自体は起動する（GitHub連携以外には影響しない）。
# 各エンドポイントを呼んだ時点でトークン未設定なら503を返す。
GITHUB_REPO_OWNER=asab0o
GITHUB_REPO_NAME=leetcode-interview-prep
GITHUB_PUSH_TOKEN=
